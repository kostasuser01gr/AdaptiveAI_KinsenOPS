{
  "appId": "com.adaptiveai.app",
  "appName": "AdaptiveAI",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#0F172A",
      "showSpinner": true,
      "spinnerColor": "#3B82F6"
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0F172A"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "ios": {
    "scheme": "AdaptiveAI",
    "contentInset": "automatic"
  },
  "android": {
    "backgroundColor": "#0F172A"
  }
}
